<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_soft">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
            android:id="@+id/tvSapaan"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Selamat bertugas, Dosen ..."
            android:textColor="@color/primary_text"
            android:textSize="22sp"
            android:textStyle="bold"
            android:layout_marginBottom="16dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@android:color/white"
            android:padding="18dp"
            android:layout_marginBottom="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Jumlah Mahasiswa"
                android:textStyle="bold"
                android:textColor="@color/primary_text"
                android:layout_marginBottom="8dp" />

            <EditText
                android:id="@+id/etJumlahMahasiswa"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Contoh: 30"
                android:inputType="number"
                android:minHeight="48dp"
                android:padding="12dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Rata-rata Nilai Kelas"
                android:textStyle="bold"
                android:textColor="@color/primary_text"
                android:layout_marginTop="14dp"
                android:layout_marginBottom="8dp" />

            <EditText
                android:id="@+id/etRataRata"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Contoh: 78.5"
                android:inputType="numberDecimal"
                android:minHeight="48dp"
                android:padding="12dp" />

            <Button
                android:id="@+id/btnProses"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="PROSES DATA"
                android:textStyle="bold"
                android:layout_marginTop="18dp" />
        </LinearLayout>

        <TextView
            android:id="@+id/tvHasil"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@android:color/white"
            android:padding="18dp"
            android:text="Hasil akan muncul di sini"
            android:textColor="@color/primary_text"
            android:textSize="16sp" />

    </LinearLayout>
</ScrollView>